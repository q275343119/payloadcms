# Local defaults are provided for development. Replace every value in production.
DATABASE_URL=postgres://payload:payload@localhost:5432/payload
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32
SITE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
PORT=3000

# Leave all R2 variables empty in local development to use ./media.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.example.com
